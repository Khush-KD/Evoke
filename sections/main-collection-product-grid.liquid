{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Luxury Minimalist Sort Dropdown & Toolbar */
  .facets-vertical-sort {
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }
  
  .facets-vertical-form {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .facet-filters.sorting {
    padding: 0;
  }

  .facet-filters__field {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .facet-filters__label {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400; /* Minimalist Non-Bold label */
    color: rgba(var(--color-foreground), 0.5);
  }

  /* Custom Modern Borderless Select Styling */
  .select {
    position: relative;
    display: inline-block;
  }

  .select select.facet-filters__sort {
    font-family: inherit;
    font-size: 11px;
    font-weight: 500; /* Minimalist Non-Bold weight matching filter standards */
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 6px 24px 6px 8px; /* Balanced little padding for perfect visual alignment */
    border: none; /* Completely borderless dropdown container */
    background-color: transparent;
    color: rgb(var(--color-foreground));
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    transition: color 0.2s ease;
    min-width: auto;
  }

  .select select.facet-filters__sort:hover,
  .select select.facet-filters__sort:focus {
    color: rgba(var(--color-foreground), 0.7);
    outline: none;
    box-shadow: none;
  }

  .select .svg-wrapper {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    pointer-events: none;
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
    color: rgba(var(--color-foreground), 0.5);
  }

  .select select.facet-filters__sort:focus + .svg-wrapper {
    transform: translateY(-50%) rotate(180deg);
    color: rgb(var(--color-foreground));
  }

  /* Disable hover underlines on filtering accordion titles ("Availability", "Price", etc) */
  .facets__summary:hover .facets__summary-label,
  .facets__summary-label:hover,
  .facets__summary:hover,
  .facets-layout-grid summary:hover,
  .facets__disclosure summary:hover,
  summary:hover .facets__summary-label,
  summary:hover span {
    text-decoration: none !important;
    text-underline-offset: unset !important;
  }

  /* Refined Product Count style */
  .product-count-vertical {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .product-count__text {
    margin: 0;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.6);
  }

  /* Optimized Grid adjustments */
  .product-grid-container {
    padding-top: 8px;
    position: relative;
  }

  /* Smooth Fade Transition for Multi-collection Grid Updates */
  .multi-filter-loading #product-grid {
    opacity: 0.25;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  /* Luxury Custom Collection Checkbox Styling */
  .custom-collection-filters {
    margin-bottom: 25px;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    padding-bottom: 15px;
  }
  .custom-collection-filters .facets__summary {
    padding: 10px 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .custom-collection-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .custom-checkbox-ui {
    width: 16px;
    height: 16px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: all 0.2s cubic-bezier(0.165, 0.84, 0.44, 1);
    background-color: transparent;
  }
  .custom-collection-checkbox:checked + .custom-checkbox-ui {
    background-color: rgb(var(--color-foreground));
    border-color: rgb(var(--color-foreground)) !important;
  }
  .custom-collection-checkbox:checked + .custom-checkbox-ui .icon-checkmark {
    visibility: visible !important;
    color: rgb(var(--color-background));
  }
  .facet-checkbox:hover .custom-checkbox-ui {
    border-color: rgba(var(--color-foreground), 0.6);
  }

  /* ── Modern Premium Bold Pagination ─────────────────── */
  .pagination-wrapper {
    margin-top: 6rem;
    margin-bottom: 4rem;
    padding-top: 4rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .pagination {
    max-width: 100%;
    margin: 0 auto !important;
    border: none !important;
    box-shadow: none !important;
  }

  .pagination__list {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .pagination__list li {
    margin: 0;
    padding: 0;
  }

  .pagination-wrapper a,
  .pagination-wrapper a:hover,
  .pagination-wrapper a:focus,
  .pagination-wrapper a:active,
  .pagination__item,
  .pagination__item:hover,
  .pagination__item:focus,
  .pagination__item:active {
    text-decoration: none !important;
    text-underline-offset: unset !important;
    border-bottom: none !important;
    outline: none !important;
    box-shadow: none !important;
  }

  .pagination__item.link::after,
  .pagination__item::after {
    display: none !important;
  }

  .pagination__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0;
    margin: 0;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700 !important;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.55) !important;
    background-color: transparent !important;
    border: 1px solid transparent !important;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    cursor: pointer;
  }

  /* Hover States */
  a.pagination__item:hover,
  .pagination__item:hover {
    color: rgb(var(--color-foreground)) !important;
    background-color: rgba(var(--color-foreground), 0.05) !important;
    border-color: rgba(var(--color-foreground), 0.08) !important;
    transform: translateY(-1px);
    text-decoration: none !important;
  }

  /* Current Active Page Styling */
  .pagination__item--current,
  .pagination__item[aria-current="page"],
  .pagination__item.pagination__item--current {
    color: rgb(var(--color-background)) !important;
    background-color: rgb(var(--color-foreground)) !important;
    font-weight: 700 !important;
    border-color: rgb(var(--color-foreground)) !important;
    box-shadow: 0 4px 12px rgba(var(--color-foreground), 0.15);
    text-decoration: none !important;
  }

  .pagination__item--next,
  .pagination__item--prev {
    color: rgba(var(--color-foreground), 0.7) !important;
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.25s ease;
    text-decoration: none !important;
  }

  .pagination__item--prev:hover {
    transform: translateX(-4px) !important;
  }

  .pagination__item--next:hover {
    transform: translateX(4px) !important;
  }

  .pagination__item svg,
  .pagination__item .icon-caret {
    width: 10px;
    height: 10px;
    fill: currentColor;
    display: inline-block;
    vertical-align: middle;
    transition: transform 0.25s ease;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | id }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {%- if section.settings.filter_collections != blank -%}
            <!-- Luxury Custom Multi-Collection Filter Accordion -->
            <div class="custom-collection-filters facet-filters">
              <details class="disclosure-has-popup facets__disclosure js-filter" data-index="custom-collections" open>
                <summary class="facets__summary caption-large focus-inset" style="list-style: none;">
                  <div style="display: flex; justify-content: space-between; width: 100%; align-items: center;">
                    <span class="facets__summary-label" style="font-weight: 500; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(var(--color-foreground), 0.5);">
                      Shop by Collections
                    </span>
                    <span class="svg-wrapper" style="width: 10px; height: 10px; opacity: 0.6;">
                      <svg viewBox="0 0 10 6" class="icon icon-caret" style="width: 10px; height: 10px; fill: currentColor;">
                        <path d="M9.707 1.293a1 1 0 00-1.414 0L5 4.586 1.707 1.293a1 1 0 00-1.414 1.414l4 4a1 1 0 001.414 0l4-4a1 1 0 000-1.414z"/>
                      </svg>
                    </span>
                  </div>
                </summary>
                <div class="facets__display" style="padding-top: 15px;">
                  <ul class="facets__list list-unstyled" role="list">
                    {%- for filter_collection in section.settings.filter_collections -%}
                      <li class="list-menu__item facets__item" style="margin-bottom: 12px;">
                        <label class="facet-checkbox" style="display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 13px; position: relative;">
                          <input type="checkbox"
                            value="{{ filter_collection.handle }}"
                            class="custom-collection-checkbox"
                          >
                          <span class="custom-checkbox-ui">
                            <svg class="icon icon-checkmark" width="10" height="10" viewBox="0 0 11 7" fill="none" xmlns="http://www.w3.org/2000/svg" style="visibility: hidden; stroke: currentColor; stroke-width: 2.5;">
                              <path d="M1.5 3.5L4.5 6L9.5 1" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                          <span class="facet-checkbox-label" style="letter-spacing: 0.04em; font-weight: 400; font-size: 12px; text-transform: uppercase;">{{ filter_collection.title }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </details>
            </div>
          {%- endif -%}

          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {%- liquid
                assign columns_desktop_int = section.settings.columns_desktop | plus: 0
                assign columns_mobile_int = section.settings.columns_mobile | plus: 0
                
                # Dynamically calculate above-the-fold count
                assign above_the_fold_count = columns_desktop_int
                if columns_mobile_int > above_the_fold_count
                  assign above_the_fold_count = columns_mobile_int
                endif
              -%}

              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {%- liquid
                  assign lazy_load = true
                  assign fetch_priority = 'auto'
                  
                  if forloop.index <= above_the_fold_count
                    assign lazy_load = false
                    assign fetch_priority = 'high'
                  endif
                -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    fetch_priority: fetch_priority,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    show_quick_actions: section.settings.show_quick_actions,
                    show_otherhover_actions: section.settings.show_otherhover_actions,
                    hide_hover_mobile: section.settings.hide_hover_actions_mobile,
                    section_id: section.id
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

<!-- High-Performance Multi-Collection AJAX Handler -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = '{{ section.id }}';
  const gridContainer = document.getElementById('ProductGridContainer');
  const grid = document.getElementById('product-grid');
  const checkboxes = document.querySelectorAll('.custom-collection-checkbox');
  const sortBySelect = document.getElementById('SortBy');
  const productCountDesktop = document.getElementById('ProductCountDesktop');
  const paginationWrapper = document.querySelector('.pagination-wrapper');

  // Cache state for restoring single collection view
  let originalGridHTML = grid ? grid.innerHTML : '';
  let originalCountHTML = productCountDesktop ? productCountDesktop.innerHTML : '';
  let originalPaginationHTML = paginationWrapper ? paginationWrapper.innerHTML : '';

  if (checkboxes.length === 0) return;

  checkboxes.forEach(checkbox => {
    checkbox.addEventListener('change', handleFilterChange);
  });

  if (sortBySelect) {
    sortBySelect.addEventListener('change', function() {
      const activeHandles = getActiveHandles();
      if (activeHandles.length > 0) {
        setTimeout(() => sortMergedProducts(sortBySelect.value), 100);
      }
    });
  }

  function getActiveHandles() {
    const active = [];
    checkboxes.forEach(cb => {
      if (cb.checked) active.push(cb.value);
    });
    return active;
  }

  async function handleFilterChange() {
    const activeHandles = getActiveHandles();

    if (gridContainer) gridContainer.classList.add('multi-filter-loading');

    if (activeHandles.length === 0) {
      if (grid) grid.innerHTML = originalGridHTML;
      if (productCountDesktop) productCountDesktop.innerHTML = originalCountHTML;
      if (paginationWrapper) {
        paginationWrapper.innerHTML = originalPaginationHTML;
        paginationWrapper.style.display = '';
      }
      if (gridContainer) gridContainer.classList.remove('multi-filter-loading');
      return;
    }

    try {
      const productIds = new Set();
      const productCards = [];
      const parser = new DOMParser();

      // Query collections concurrently via section rendering
      const promises = activeHandles.map(handle => 
        fetch(`/collections/${handle}?section_id=${sectionId}`)
          .then(res => {
            if (!res.ok) throw new Error('Network error loading collection');
            return res.text();
          })
      );

      const htmls = await Promise.all(promises);

      htmls.forEach(html => {
        const doc = parser.parseFromString(html, 'text/html');
        const cards = doc.querySelectorAll('#product-grid > li.grid__item');
        
        cards.forEach(card => {
          const cardInner = card.querySelector('.card--enhanced');
          const prodId = cardInner ? cardInner.dataset.productId : null;
          
          if (prodId) {
            if (!productIds.has(prodId)) {
              productIds.add(prodId);
              productCards.push(card);
            }
          }
        });
      });

      if (grid) {
        grid.innerHTML = '';
        if (productCards.length === 0) {
          grid.innerHTML = `<div class="collection collection--empty page-width">
            <div class="title-wrapper center">
              <h2 class="title title--primary" style="font-size: 14px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase;">
                No items match the selected collections.
              </h2>
            </div>
          </div>`;
        } else {
          productCards.forEach((card, idx) => {
            card.style.setProperty('--animation-order', idx + 1);
            grid.appendChild(card);
          });
        }
      }

      if (paginationWrapper) {
        paginationWrapper.style.display = 'none';
      }

      if (productCountDesktop) {
        productCountDesktop.textContent = `${productCards.length} Items Selected`;
      }

      if (sortBySelect) {
        sortMergedProducts(sortBySelect.value);
      }

    } catch (error) {
      console.error('[Multi-Collection Filter] Error updating grid:', error);
    } finally {
      if (gridContainer) gridContainer.classList.remove('multi-filter-loading');
    }
  }

  function sortMergedProducts(sortBy) {
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('li.grid__item'));
    if (cards.length === 0) return;

    cards.sort((a, b) => {
      const getPrice = (el) => {
        const priceEl = el.querySelector('.price--current');
        if (!priceEl) return 0;
        return parseFloat(priceEl.textContent.replace(/[^0-9.,]/g, '').replace(',', '.'));
      };

      const getTitle = (el) => {
        const titleEl = el.querySelector('.card__title a');
        return titleEl ? titleEl.textContent.trim().toLowerCase() : '';
      };

      const getIndex = (el) => {
        return parseInt(el.style.getPropertyValue('--animation-order') || '0');
      };

      switch (sortBy) {
        case 'price-ascending':
          return getPrice(a) - getPrice(b);
        case 'price-descending':
          return getPrice(b) - getPrice(a);
        case 'title-ascending':
          return getTitle(a).localeCompare(getTitle(b));
        case 'title-descending':
          return getTitle(b).localeCompare(getTitle(a));
        default:
          return getIndex(a) - getIndex(b);
      }
    });

    cards.forEach((card, idx) => {
      card.style.setProperty('--animation-order', idx + 1);
      grid.appendChild(card);
    });
  }
});
</script>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "collection_list",
      "id": "filter_collections",
      "label": "Filter Collections List",
      "info": "Display these selected collections as premium checkboxes in the filters sidebar."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
