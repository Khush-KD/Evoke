{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Luxury Minimalist Sort Dropdown & Toolbar */
  .facets-vertical-sort {
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }
  
  .facets-vertical-form {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .facet-filters.sorting {
    padding: 0;
  }

  .facet-filters__field {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .facet-filters__label {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400; /* Minimalist Non-Bold label */
    color: rgba(var(--color-foreground), 0.5);
  }

  /* Custom Modern Borderless Select Styling */
  .select {
    position: relative;
    display: inline-block;
  }

  .select select.facet-filters__sort {
    font-family: inherit;
    font-size: 11px;
    font-weight: 500; /* Minimalist Non-Bold weight matching filter standards */
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 6px 24px 6px 8px; /* Balanced little padding for perfect visual alignment */
    border: none; /* Completely borderless dropdown container */
    background-color: transparent;
    color: rgb(var(--color-foreground));
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    transition: color 0.2s ease;
    min-width: auto;
  }

  .select select.facet-filters__sort:hover,
  .select select.facet-filters__sort:focus {
    color: rgba(var(--color-foreground), 0.7);
    outline: none;
    box-shadow: none;
  }

  .select .svg-wrapper {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    pointer-events: none;
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
    color: rgba(var(--color-foreground), 0.5);
  }

  .select select.facet-filters__sort:focus + .svg-wrapper {
    transform: translateY(-50%) rotate(180deg);
    color: rgb(var(--color-foreground));
  }

  /* Disable hover underlines on filtering accordion titles ("Availability", "Price", etc) */
  .facets__summary:hover .facets__summary-label,
  .facets__summary-label:hover,
  .facets__summary:hover,
  .facets-layout-grid summary:hover,
  .facets__disclosure summary:hover,
  summary:hover .facets__summary-label,
  summary:hover span {
    text-decoration: none !important;
    text-underline-offset: unset !important;
  }

  /* Refined Product Count style */
  .product-count-vertical {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .product-count__text {
    margin: 0;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.6);
  }

  /* Optimized Grid adjustments */
  .product-grid-container {
    padding-top: 8px;
    position: relative;
  }

  /* ── Custom Premium Collections Filter Sidebar Block ── */
  .custom-collections-sidebar-filter {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    padding-bottom: 2rem;
    margin-bottom: 2rem;
  }

  .custom-collections-sidebar-filter .facets__summary {
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .custom-collections-sidebar-filter .facets__summary > div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .custom-collections-sidebar-filter .facets__summary-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .custom-collections-sidebar-filter .svg-wrapper {
    width: 12px;
    height: 12px;
    transition: transform 0.25s ease;
  }

  .custom-collections-sidebar-filter details[open] .svg-wrapper {
    transform: rotate(180deg);
  }

  .custom-collections-sidebar-filter .facets__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .custom-collections-sidebar-filter .collection-filter-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.75);
    transition: all 0.25s ease;
    padding: 2px 0;
  }

  .custom-collections-sidebar-filter .collection-filter-item:hover {
    color: rgb(var(--color-foreground));
    padding-left: 4px;
  }

  .custom-collections-sidebar-filter .collection-filter-item--active {
    color: rgb(var(--color-foreground));
    font-weight: 700;
  }

  .custom-collections-sidebar-filter .active-dot {
    width: 5px;
    height: 5px;
    background-color: rgb(var(--color-foreground));
    border-radius: 50%;
  }

  /* ── Custom Premium Horizontal Collections Tab Bar ── */
  .custom-collections-horizontal-bar {
    width: 100%;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .custom-collections-horizontal-bar__title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 1.6rem;
  }

  .custom-collections-horizontal-bar__list {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    padding: 0 0 12px 0;
    margin: 0;
    list-style: none;
  }

  .custom-collections-horizontal-bar__list::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .custom-collections-horizontal-bar__item {
    flex-shrink: 0;
  }

  .custom-collections-horizontal-bar__link {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    text-decoration: none;
    padding-bottom: 12px;
    position: relative;
    transition: color 0.25s ease;
  }

  .custom-collections-horizontal-bar__link:hover {
    color: rgb(var(--color-foreground));
  }

  .custom-collections-horizontal-bar__link--active {
    color: rgb(var(--color-foreground));
    font-weight: 700;
  }

  .custom-collections-horizontal-bar__link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: rgb(var(--color-foreground));
    transform: scaleX(0);
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .custom-collections-horizontal-bar__link--active::after {
    transform: scaleX(1);
  }

  /* ── Modern Premium Bold Pagination ─────────────────── */
  .pagination-wrapper {
    margin-top: 6rem;
    margin-bottom: 4rem;
    padding-top: 4rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .pagination {
    max-width: 100%;
    margin: 0 auto !important;
    border: none !important;
    box-shadow: none !important;
  }

  .pagination__list {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .pagination__list li {
    margin: 0;
    padding: 0;
  }

  /* Target all pagination states to explicitly clear theme underlines and links styling */
  .pagination-wrapper a,
  .pagination-wrapper a:hover,
  .pagination-wrapper a:focus,
  .pagination-wrapper a:active,
  .pagination__item,
  .pagination__item:hover,
  .pagination__item:focus,
  .pagination__item:active {
    text-decoration: none !important;
    text-underline-offset: unset !important;
    border-bottom: none !important;
    outline: none !important;
    box-shadow: none !important;
  }

  .pagination__item.link::after,
  .pagination__item::after {
    display: none !important;
  }

  .pagination__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0;
    margin: 0;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700 !important; /* Elegant Bold Weights */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.55) !important;
    background-color: transparent !important;
    border: 1px solid transparent !important;
    border-radius: 50%;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    cursor: pointer;
  }

  /* Hover States */
  a.pagination__item:hover,
  .pagination__item:hover {
    color: rgb(var(--color-foreground)) !important;
    background-color: rgba(var(--color-foreground), 0.05) !important;
    border-color: rgba(var(--color-foreground), 0.08) !important;
    transform: translateY(-1px);
    text-decoration: none !important;
  }

  /* Current Active Page Styling */
  .pagination__item--current,
  .pagination__item[aria-current="page"],
  .pagination__item.pagination__item--current {
    color: rgb(var(--color-background)) !important;
    background-color: rgb(var(--color-foreground)) !important;
    font-weight: 700 !important; /* Bold current state */
    border-color: rgb(var(--color-foreground)) !important;
    box-shadow: 0 4px 12px rgba(var(--color-foreground), 0.15);
    text-decoration: none !important;
  }

  /* Prev/Next Navigation buttons */
  .pagination__item--next,
  .pagination__item--prev {
    color: rgba(var(--color-foreground), 0.7) !important;
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.25s ease;
    text-decoration: none !important;
  }

  .pagination__item--prev:hover {
    transform: translateX(-4px) !important;
  }

  .pagination__item--next:hover {
    transform: translateX(4px) !important;
  }

  /* Clean up caret sizing inside container */
  .pagination__item svg,
  .pagination__item .icon-caret {
    width: 10px;
    height: 10px;
    fill: currentColor;
    display: inline-block;
    vertical-align: middle;
    transition: transform 0.25s ease;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      
      {%- if section.settings.enable_filtering or section.settings.enable_sorting or section.settings.enable_collections_filter -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {%- liquid
            assign show_sidebar_collections = false
            if section.settings.enable_collections_filter and section.settings.filter_collections != blank
              if section.settings.collections_filter_style == 'sidebar' or section.settings.collections_filter_style == 'both'
                assign show_sidebar_collections = true
              elsif section.settings.collections_filter_style == 'auto' and section.settings.filter_type == 'vertical'
                assign show_sidebar_collections = true
              endif
            endif
          -%}

          {%- if show_sidebar_collections -%}
            <!-- Premium Sidebar Collection Filter Block -->
            <div class="custom-collections-sidebar-filter facets__disclosure">
              <details id="Details-Collections-Sidebar" class="disclosure-has-popup facets__disclosure-details" open>
                <summary class="facets__summary caption-large focus-inset">
                  <div>
                    <span class="facets__summary-label color-foreground">{{ section.settings.collections_filter_title | escape }}</span>
                    <span class="svg-wrapper">
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </span>
                  </div>
                </summary>
                <div id="Facet-Collections-Sidebar-Display" class="facets__display">
                  <ul class="facets__list list-unstyled" role="list">
                    {%- for filtered_col in section.settings.filter_collections -%}
                      <li>
                        <a 
                          href="{{ filtered_col.url }}" 
                          class="collection-filter-item{% if collection.handle == filtered_col.handle %} collection-filter-item--active{% endif %}"
                        >
                          <span>{{ filtered_col.title | escape }}</span>
                          {%- if collection.handle == filtered_col.handle -%}
                            <span class="active-dot"></span>
                          {%- endif -%}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </details>
            </div>
          {%- endif -%}

          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- liquid
          assign show_horizontal_collections = false
          if section.settings.enable_collections_filter and section.settings.filter_collections != blank
            if section.settings.collections_filter_style == 'horizontal' or section.settings.collections_filter_style == 'both'
              assign show_horizontal_collections = true
            elsif section.settings.collections_filter_style == 'auto' and section.settings.filter_type != 'vertical'
              assign show_horizontal_collections = true
            endif
          endif
        -%}

        {%- if show_horizontal_collections -%}
          <!-- Premium Horizontal Ribbon Collections Filter Bar -->
          <div class="custom-collections-horizontal-bar page-width">
            {%- if section.settings.collections_filter_title != blank -%}
              <h3 class="custom-collections-horizontal-bar__title">{{ section.settings.collections_filter_title | escape }}</h3>
            {%- endif -%}
            <ul class="custom-collections-horizontal-bar__list" role="list">
              {%- for filtered_col in section.settings.filter_collections -%}
                <li class="custom-collections-horizontal-bar__item">
                  <a 
                    href="{{ filtered_col.url }}" 
                    class="custom-collections-horizontal-bar__link{% if collection.handle == filtered_col.handle %} custom-collections-horizontal-bar__link--active{% endif %}"
                  >
                    {{ filtered_col.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {%- liquid
                assign columns_desktop_int = section.settings.columns_desktop | plus: 0
                assign columns_mobile_int = section.settings.columns_mobile | plus: 0
                
                # Dynamically calculate above-the-fold count
                assign above_the_fold_count = columns_desktop_int
                if columns_mobile_int > above_the_fold_count
                  assign above_the_fold_count = columns_mobile_int
                endif
              -%}

              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {%- liquid
                  assign lazy_load = true
                  assign fetch_priority = 'auto'
                  
                  if forloop.index <= above_the_fold_count
                    assign lazy_load = false
                    assign fetch_priority = 'high'
                  endif
                -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    fetch_priority: fetch_priority,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    show_quick_actions: section.settings.show_quick_actions,
                    show_otherhover_actions: section.settings.show_otherhover_actions,
                    hide_hover_mobile: section.settings.hide_hover_actions_mobile,
                    section_id: section.id
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },    
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
