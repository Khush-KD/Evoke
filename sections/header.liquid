{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Logo Layout"
    },
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "middle-left", "label": "Middle left" },
        { "value": "middle-center", "label": "Middle center (centered logo)" }
      ],
      "default": "middle-left",
      "label": "t:sections.header.settings.logo_position.label",
      "info": "t:sections.header.settings.logo_help.content"
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center",
      "label": "t:sections.header.settings.mobile_logo_position.label"
    },
    {
      "type": "range",
      "id": "header_height_desktop",
      "min": 48,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Header height (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "header_height_mobile",
      "min": 48,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Header height (mobile)",
      "default": 60
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        { "value": "dropdown", "label": "Dropdown" },
        { "value": "mega", "label": "Mega menu" },
        { "value": "drawer", "label": "Drawer" }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label"
    },
    {
      "type": "select",
      "id": "mobile_nav_style",
      "options": [
        { "value": "drawer", "label": "Slide-in drawer" },
        { "value": "fullscreen", "label": "Full-screen overlay" }
      ],
      "default": "drawer",
      "label": "Mobile nav style"
    },
    {
      "type": "header",
      "content": "Sticky & Scroll Behavior"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up", "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always", "label": "t:sections.header.settings.sticky_header_type.options__3.label" },
        { "value": "reduce-logo-size", "label": "Shrink on scroll" }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
