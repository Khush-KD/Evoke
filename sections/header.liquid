<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-header-enhanced.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  :root {
    --header-height-desktop: {{ section.settings.header_height_desktop }}px;
    --header-height-mobile: {{ section.settings.header_height_mobile }}px;
    --header-bg-color: {{ section.settings.header_bg_color }};
    --header-text-color: {{ section.settings.header_text_color }};
    --header-hover-color: {{ section.settings.header_hover_color }};
    --header-border-color: {{ section.settings.header_border_color }};
    --header-border-thickness: {{ section.settings.header_border_thickness }}px;
  }

  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

/* =============================================
     TRANSPARENT HEADER + SCROLLED COLORS
     ============================================= */
  {%- if section.settings.enable_transparent_header -%}

  /*
   * --hw-text and --hw-icon are set in TWO states:
   *   1. .header-transparent  → transparent colors (white by default)
   *   2. :not(.header-transparent) → scrolled colors (dark by default)
   * This is the ONLY place these variables are defined.
   */

  /* ── TRANSPARENT STATE: use the "transparent header" color settings ── */

  .header-wrapper.header-transparent {
    background: transparent !important;
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  .header-wrapper.header-transparent::after { display: none; }
 
  /* ── TRANSPARENT: force text/icon color to transparent-header setting ── */
  .header-wrapper.header-transparent .header__menu-item,
  .header-wrapper.header-transparent .header__menu-item span,
  .header-wrapper.header-transparent .header__heading-link,
  .header-wrapper.header-transparent .header__heading-link .h2,
  .header-wrapper.header-transparent .header__heading-link span {
    color: {{ section.settings.transparent_header_text_color }} !important;
    transition: color 0.35s ease;
  }
  .header-wrapper.header-transparent .header__icon,
  .header-wrapper.header-transparent header-drawer {
    color: {{ section.settings.transparent_header_icon_color }} !important;
    transition: color 0.35s ease;
  }
  .header-wrapper.header-transparent .header__icon svg *,
  .header-wrapper.header-transparent header-drawer svg * {
    stroke: currentColor !important;
    transition: stroke 0.35s ease;
  }
  .header-wrapper.header-transparent .localization-selector button,
  .header-wrapper.header-transparent .localization-form__select,
  .header-wrapper.header-transparent .disclosure__button,
  .header-wrapper.header-transparent .disclosure__button span {
    color: {{ section.settings.transparent_header_icon_color }} !important;
    transition: color 0.35s ease;
  }
  .header-wrapper.header-transparent .localization-selector svg path,
  .header-wrapper.header-transparent .disclosure__button svg path,
  .header-wrapper.header-transparent .icon-caret path {
    stroke: {{ section.settings.transparent_header_icon_color }} !important;
    fill:   {{ section.settings.transparent_header_icon_color }} !important;
  }
  .header-wrapper.header-transparent .header__account-dropdown > a::after {
    border-color: {{ section.settings.transparent_header_icon_color }} !important;
  }
  .header-wrapper.header-transparent .header__heading-logo {
    filter: var(--hw-logo-filter, none);
    transition: filter 0.35s ease;
  }
 
/* ── SCROLLED STATE: only when glassmorphism or solid bg is active ── */
  .section-header.scrolled .header-wrapper .header__menu-item,
  .section-header.scrolled .header-wrapper .header__menu-item span,
  .section-header.scrolled .header-wrapper .header__heading-link,
  .section-header.scrolled .header-wrapper .header__heading-link .h2,
  .section-header.scrolled .header-wrapper .header__heading-link span,
  .shopify-section-header-sticky .header-wrapper .header__menu-item,
  .shopify-section-header-sticky .header-wrapper .header__menu-item span,
  .shopify-section-header-sticky .header-wrapper .header__heading-link,
  .shopify-section-header-sticky .header-wrapper .header__heading-link .h2,
  .shopify-section-header-sticky .header-wrapper .header__heading-link span {
    color: {{ section.settings.scrolled_header_text_color }} !important;
    transition: color 0.35s ease;
  }
  .section-header.scrolled .header-wrapper .header__icon,
  .section-header.scrolled .header-wrapper header-drawer,
  .shopify-section-header-sticky .header-wrapper .header__icon,
  .shopify-section-header-sticky .header-wrapper header-drawer {
    color: {{ section.settings.scrolled_header_icon_color }} !important;
    transition: color 0.35s ease;
  }
  .section-header.scrolled .header-wrapper .header__icon svg *,
  .section-header.scrolled .header-wrapper header-drawer svg *,
  .shopify-section-header-sticky .header-wrapper .header__icon svg *,
  .shopify-section-header-sticky .header-wrapper header-drawer svg * {
    stroke: currentColor !important;
    transition: stroke 0.35s ease;
  }
  .section-header.scrolled .header-wrapper .localization-selector button,
  .section-header.scrolled .header-wrapper .localization-form__select,
  .section-header.scrolled .header-wrapper .disclosure__button,
  .section-header.scrolled .header-wrapper .disclosure__button span,
  .shopify-section-header-sticky .header-wrapper .localization-selector button,
  .shopify-section-header-sticky .header-wrapper .localization-form__select,
  .shopify-section-header-sticky .header-wrapper .disclosure__button,
  .shopify-section-header-sticky .header-wrapper .disclosure__button span {
    color: {{ section.settings.scrolled_header_icon_color }} !important;
    transition: color 0.35s ease;
  }
  .section-header.scrolled .header-wrapper .localization-selector svg path,
  .section-header.scrolled .header-wrapper .disclosure__button svg path,
  .section-header.scrolled .header-wrapper .icon-caret path,
  .shopify-section-header-sticky .header-wrapper .localization-selector svg path,
  .shopify-section-header-sticky .header-wrapper .disclosure__button svg path,
  .shopify-section-header-sticky .header-wrapper .icon-caret path {
    stroke: {{ section.settings.scrolled_header_icon_color }} !important;
    fill:   {{ section.settings.scrolled_header_icon_color }} !important;
  }
  .section-header.scrolled .header-wrapper .header__account-dropdown > a::after,
  .shopify-section-header-sticky .header-wrapper .header__account-dropdown > a::after {
    border-color: {{ section.settings.scrolled_header_icon_color }} !important;
    transition: border-color 0.35s ease;
  }
  .section-header.scrolled .header-wrapper .header__heading-logo,
  .shopify-section-header-sticky .header-wrapper .header__heading-logo {
    filter: none;
    transition: filter 0.35s ease;
  }
  .header-wrapper {
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
  }

  {%- endif -%}

  /* =============================================
     SOLID COLOR ON SCROLL
     (works independently — no transparent header required)
     ============================================= */
  {%- if section.settings.enable_solid_color_on_scroll -%}
  .section-header.scrolled .header-wrapper,
  .shopify-section-header-sticky .header-wrapper,
  .shopify-section-header-hidden .header-wrapper {
    background: {{ section.settings.scroll_header_bg_color }} !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }
  {%- endif -%}

  /* =============================================
     GLASSMORPHISM
     ============================================= */
  {%- if section.settings.enable_glassmorphism -%}
  .section-header.scrolled .header-wrapper,
  .shopify-section-header-sticky .header-wrapper {
    background: rgba(255,255,255,0.72) !important;
    backdrop-filter: blur(16px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(16px) saturate(180%) !important;
    border-bottom: 1px solid rgba(255,255,255,0.3) !important;
  }
  {%- endif -%}

  /* =============================================
     HOVER UNDERLINE ANIMATION
     ============================================= */
  {%- if section.settings.enable_hover_underline -%}
  .header__menu-item span,
  .header__menu-item {
    position: relative;
  }
  .header__menu-item > span::after,
  .header__inline-menu .list-menu__item > span::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: currentColor;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .header__menu-item:hover > span::after,
  .header__inline-menu .list-menu__item:hover > span::after {
    width: 100%;
  }
  {%- endif -%}

  /* =============================================
     BORDER ON SCROLL
     ============================================= */
  {%- if section.settings.show_border_on_scroll -%}
  .header-wrapper {
    border-bottom: var(--header-border-thickness) solid transparent;
    transition: border-color 0.3s ease;
  }
  .section-header.scrolled .header-wrapper,
  .shopify-section-header-sticky .header-wrapper {
    border-bottom-color: var(--header-border-color) !important;
  }
  {%- elsif section.settings.show_line_separator -%}
  .header-wrapper--border-bottom {
    border-bottom: var(--header-border-thickness) solid var(--header-border-color);
  }
  {%- endif -%}

  /* =============================================
     WISHLIST ICON
     ============================================= */
  .header__icon--wishlist {
    position: relative;
  }
  .header__icon--wishlist .wishlist-count-bubble {
    position: absolute;
    top: -4px;
    right: -4px;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border-radius: 50%;
    width: 1.6rem;
    height: 1.6rem;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  /* =============================================
     INLINE SEARCH
     ============================================= */
  {%- if section.settings.search_style == 'inline' -%}
  .header__search-inline {
    display: flex;
    align-items: center;
    border: 1px solid currentColor;
    border-radius: 2rem;
    padding: 0.4rem 1.2rem;
    gap: 0.6rem;
    opacity: 0.6;
    transition: opacity 0.2s, width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    width: 14rem;
  }
  .header__search-inline:focus-within {
    opacity: 1;
    width: 22rem;
  }
  .header__search-inline input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 1.3rem;
    color: inherit;
    width: 100%;
  }
  {%- endif -%}

  /* =============================================
     ACCOUNT DROPDOWN
     ============================================= */
  .header__account-dropdown {
    position: relative;
  }
  .header__account-dropdown-menu {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    min-width: 16rem;
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 0.8rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    padding: 0.8rem 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 100;
  }
  .header__account-dropdown:hover .header__account-dropdown-menu,
  .header__account-dropdown:focus-within .header__account-dropdown-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .header__account-dropdown-menu a {
    display: block;
    padding: 0.9rem 1.6rem;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    font-size: 1.3rem;
    transition: background 0.15s;
  }
  .header__account-dropdown-menu a:hover {
    background: rgba(var(--color-foreground), 0.06);
  }
  .header__account-dropdown-menu .account-dropdown__divider {
    height: 1px;
    background: rgba(var(--color-foreground), 0.1);
    margin: 0.5rem 0;
  }

  .mini-cart-overlay,
  .mini-cart-drawer {
    z-index: 99999;
    isolation: auto; /* don't trap inside a stacking context */
  }

  /* =============================================
     MINI CART DRAWER
     ============================================= */
  .mini-cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 99998;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .mini-cart-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .mini-cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: min(42rem, 100vw);
    height: 100vh;
    background: rgb(var(--color-background));
    z-index: 99999;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.15);
  }
  .mini-cart-drawer.is-open {
    transform: translateX(0);
  }
  .mini-cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 2.4rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }
  .mini-cart-drawer__title {
    font-size: 1.8rem;
    font-weight: 600;
    margin: 0;
  }
  .mini-cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    color: rgb(var(--color-foreground));
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .mini-cart-drawer__close:hover { opacity: 1; }
  .mini-cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 2rem 2.4rem;
  }
  .mini-cart-drawer__footer {
    padding: 2rem 2.4rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }
  .mini-cart-drawer__footer .button {
    width: 100%;
    text-align: center;
  }
  .mini-cart-item {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    gap: 1.4rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.06);
  }
  .mini-cart-item img {
    width: 7rem;
    height: 7rem;
    object-fit: cover;
    border-radius: 0.4rem;
  }
  .mini-cart-item__title {
    font-size: 1.3rem;
    font-weight: 500;
    margin: 0 0 0.4rem;
  }
  .mini-cart-item__price {
    font-size: 1.3rem;
    opacity: 0.7;
  }
  .mini-cart-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.2s;
    color: rgb(var(--color-foreground));
    font-size: 1.8rem;
    line-height: 1;
    padding: 0.2rem;
  }
  .mini-cart-item__remove:hover { opacity: 1; }
  .mini-cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.6rem;
    font-weight: 600;
    font-size: 1.5rem;
  }
  .mini-cart-drawer__empty {
    text-align: center;
    padding: 4rem 0;
    opacity: 0.5;
    font-size: 1.4rem;
  }

  /* =============================================
     MOBILE BOTTOM NAV
     ============================================= */
  {%- if section.settings.enable_mobile_bottom_nav -%}
  .header__bottom-nav {
    display: none;
  }
  @media screen and (max-width: 749px) {
    .header__bottom-nav {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 150;
      background: rgb(var(--color-background));
      border-top: 1px solid rgba(var(--color-foreground), 0.1);
      padding: 0.8rem 0 calc(0.8rem + env(safe-area-inset-bottom));
      justify-content: space-around;
      align-items: center;
    }
    .header__bottom-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      text-decoration: none;
      color: rgb(var(--color-foreground));
      font-size: 1rem;
      opacity: 0.6;
      transition: opacity 0.2s;
      padding: 0.4rem 1.2rem;
    }
    .header__bottom-nav-item.active,
    .header__bottom-nav-item:hover { opacity: 1; }
    .header__bottom-nav-item svg { width: 2.2rem; height: 2.2rem; }
    body { padding-bottom: 6rem; }
  }
  {%- endif -%}

  /* =============================================
     FULL-SCREEN MOBILE NAV
     ============================================= */
  {%- if section.settings.mobile_nav_style == 'fullscreen' -%}
  @media screen and (max-width: 989px) {
    .menu-drawer {
      width: 100vw !important;
      height: 100vh !important;
      left: 0 !important;
      top: 0 !important;
    }
  }
  {%- endif -%}

  /* =============================================
     SHRINK ON SCROLL
     ============================================= */
  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
  .header-wrapper {
    transition: padding 0.3s ease;
  }
  .shopify-section-header-sticky .header {
    padding-top: {{ section.settings.padding_top | times: 0.4 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.4 | round: 0 }}px;
    transition: padding 0.3s ease;
  }
  {%- endif -%}
  
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
    min-height: {{ section.settings.header_height_mobile }}px;
  }

  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      min-height: {{ section.settings.header_height_desktop }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'header-enhanced.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{%- liquid
  assign header_tag = 'div'
  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
-%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}data-sticky-type="{{ section.settings.sticky_header_type }}"{% endif %}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator and section.settings.show_border_on_scroll == false %} header-wrapper--border-bottom{% endif %}{% if section.settings.enable_transparent_header %} header-transparent{% endif %}"
  {% if section.settings.enable_transparent_header %}data-transparent-header{% endif %}
>
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}

  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}">
    {%- liquid
      if section.settings.menu != blank
        render 'header-drawer'
      endif

      if section.settings.logo_position == 'top-center' or section.settings.menu == blank
        render 'header-search', input_id: 'Search-In-Modal-1'
      endif
    -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
            {%- if settings.logo != blank -%}
              <div class="header__heading-logo-wrapper">
                {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
                {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
                {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
                {{ settings.logo | image_url: width: 600 | image_tag:
                  class: 'header__heading-logo motion-reduce',
                  widths: widths,
                  height: logo_height,
                  width: settings.logo_width,
                  alt: logo_alt,
                  sizes: sizes,
                  preload: true
                }}
              </div>
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    {%- liquid
      if section.settings.menu != blank
        if section.settings.menu_type_desktop == 'dropdown'
          render 'header-dropdown-menu'
        elsif section.settings.menu_type_desktop != 'drawer'
          render 'header-mega-menu'
        endif
      endif
    %}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
            {%- if settings.logo != blank -%}
              <div class="header__heading-logo-wrapper">
                {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
                {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
                {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
                {{ settings.logo | image_url: width: 600 | image_tag:
                  class: 'header__heading-logo',
                  widths: widths,
                  height: logo_height,
                  width: settings.logo_width,
                  alt: logo_alt,
                  sizes: sizes,
                  preload: true
                }}
              </div>
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      {%- comment -%} Inline Search {%- endcomment -%}
      {%- if section.settings.search_style == 'inline' -%}
        <form action="{{ routes.search_url }}" method="get" class="header__search-inline small-hide">
          <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
          <input type="search" name="q" placeholder="{{ 'general.search.search' | t }}" value="{{ search.terms | escape }}">
          <input type="hidden" name="options[prefix]" value="last">
        </form>
      {%- else -%}
        {% render 'header-search', input_id: 'Search-In-Modal' %}
      {%- endif -%}

      {%- comment -%} Wishlist Icon {%- endcomment -%}
      {%- if section.settings.show_wishlist_icon -%}
        <a href="{{ routes.root_url }}pages/wishlist" class="header__icon header__icon--wishlist link focus-inset" aria-label="Wishlist">
          <span class="svg-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </span>
          <span class="visually-hidden">Wishlist</span>
          <div class="wishlist-count-bubble" id="wishlist-count" style="display:none">0</div>
        </a>
      {%- endif -%}

      {%- comment -%} Account with Dropdown {%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        {%- if section.settings.enable_account_dropdown -%}
          <div class="header__account-dropdown">
            <a
              href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
              class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
              rel="nofollow"
            >
              {%- if section.settings.enable_customer_avatar -%}
                <account-icon>
                  {%- if customer and customer.has_avatar? -%}
                    {{ customer | avatar }}
                  {%- else -%}
                    <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
                  {%- endif -%}
                </account-icon>
              {%- else -%}
                <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              {%- endif -%}
              <span class="visually-hidden">
                {%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}
              </span>
            </a>
            <div class="header__account-dropdown-menu">
              {%- if customer -%}
                <a href="{{ routes.account_url }}">My Account</a>
                <a href="{{ routes.account_orders_url }}">Orders</a>
                <div class="account-dropdown__divider"></div>
                <a href="{{ routes.account_logout_url }}">Sign Out</a>
              {%- else -%}
                <a href="{{ routes.account_login_url }}">Sign In</a>
                <a href="{{ routes.account_register_url }}">Create Account</a>
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
            rel="nofollow"
          >
            {%- if section.settings.enable_customer_avatar -%}
              <account-icon>
                {%- if customer and customer.has_avatar? -%}{{ customer | avatar }}{%- else -%}<span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>{%- endif -%}
              </account-icon>
            {%- else -%}
              <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
            {%- endif -%}
            <span class="visually-hidden">
              {%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}
            </span>
          </a>
        {%- endif -%}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Cart Icon — triggers mini drawer if enabled {%- endcomment -%}
      {%- if section.settings.enable_mini_cart -%}
        <button
          class="header__icon header__icon--cart link focus-inset"
          id="cart-icon-bubble"
          aria-label="{{ 'templates.cart.cart' | t }}"
          data-mini-cart-trigger
        >
          {% if cart == empty %}
            <span class="svg-wrapper">{{'icon-cart-empty.svg' | inline_asset_content }}</span>
          {% else %}
            <span class="svg-wrapper">{{'icon-cart.svg' | inline_asset_content }}</span>
          {% endif %}
          <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
          {%- if cart != empty -%}
            <div class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          {%- endif -%}
        </button>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
          {% if cart == empty %}
            <span class="svg-wrapper">{{'icon-cart-empty.svg' | inline_asset_content }}</span>
          {% else %}
            <span class="svg-wrapper">{{'icon-cart.svg' | inline_asset_content }}</span>
          {% endif %}
          <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
          {%- if cart != empty -%}
            <div class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </header>
</{{ header_tag }}>

{%- comment -%} Mini Cart Drawer {%- endcomment -%}
{%- if section.settings.enable_mini_cart -%}
<div class="mini-cart-overlay" id="mini-cart-overlay" data-mini-cart-overlay></div>
<div class="mini-cart-drawer" id="mini-cart-drawer" aria-label="Cart" role="dialog" data-mini-cart>
  <div class="mini-cart-drawer__header">
    <h2 class="mini-cart-drawer__title">Your Cart</h2>
    <button class="mini-cart-drawer__close" aria-label="Close cart" data-mini-cart-close>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="mini-cart-drawer__body" id="mini-cart-body">
    {%- if cart == empty -%}
      <p class="mini-cart-drawer__empty">Your cart is empty.</p>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="mini-cart-item" data-key="{{ item.key }}">
          <img src="{{ item.image | image_url: width: 140 }}" alt="{{ item.title | escape }}" width="70" height="70">
          <div>
            <p class="mini-cart-item__title">{{ item.product.title }}</p>
            {%- unless item.product.has_only_default_variant -%}
              <p class="mini-cart-item__price">{{ item.variant.title }}</p>
            {%- endunless -%}
            <p class="mini-cart-item__price">Qty: {{ item.quantity }} · {{ item.line_price | money }}</p>
          </div>
          <button class="mini-cart-item__remove" data-remove-key="{{ item.key }}" aria-label="Remove {{ item.title | escape }}">&#x2715;</button>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
  <div class="mini-cart-drawer__footer">
    <div class="mini-cart-drawer__subtotal">
      <span>Subtotal</span>
      <span id="mini-cart-subtotal">{{ cart.total_price | money }}</span>
    </div>
    <a href="{{ routes.cart_url }}" class="button button--primary">View Cart</a>
    <a href="/checkout" class="button" style="margin-top:0.8rem">Checkout</a>
  </div>
</div>
{%- endif -%}

