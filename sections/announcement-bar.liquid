{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
  if section.settings.enable_country_selector or section.settings.enable_language_selector
    assign language_country_selector = true
  endif
  if section.blocks.size > 0
    assign announcement_bar = true
  endif
-%}

{% if social_icons %}
  {{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{% endif %}

<style>
  #utility-bar-{{ section.id }} {
    position: relative;
    z-index: 10;
  }
  .announcement-bar-section {
    position: relative;
    z-index: 1; /* Below the mini cart overlay */
  }
  #utility-bar-{{ section.id }} .utility-bar__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-top: {{ section.settings.bar_padding }}px;
    padding-bottom: {{ section.settings.bar_padding }}px;
  }
  {%- if section.settings.section_width == 'full' -%}
  #utility-bar-{{ section.id }} .utility-bar__inner {
    padding-left: {{ section.settings.bar_padding }}px;
    padding-right: {{ section.settings.bar_padding }}px;
    max-width: 100%;
    width: 100%;
  }
  {%- endif -%}
  #utility-bar-{{ section.id }} .utility-bar__left,
  #utility-bar-{{ section.id }} .utility-bar__center,
  #utility-bar-{{ section.id }} .utility-bar__right {
    min-width: 0;
  }
  #utility-bar-{{ section.id }} .utility-bar__left {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  #utility-bar-{{ section.id }} .utility-bar__center {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  #utility-bar-{{ section.id }} .utility-bar__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* Announcement Bar Slide Container Rules */
  #utility-bar-{{ section.id }} .announcement-bar {
    position: relative;
    width: 100%;
  }

  /* Flip-through animations */
  #utility-bar-{{ section.id }} .announcement-bar-slider {
    overflow: hidden;
    perspective: 400px;
    width: 100%;
  }

  #utility-bar-{{ section.id }} .announcement-bar-slider .slider {
    position: relative;
    overflow: hidden;
    min-height: 3.8rem;
  }

  #utility-bar-{{ section.id }} .announcement-bar-slider .slider__slide {
    position: relative;
    pointer-events: none;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  #utility-bar-{{ section.id }} .announcement-bar-slider .slider__slide[aria-hidden="false"] {
    pointer-events: auto;
  }

  #utility-bar-{{ section.id }} .announcement-bar__message {
    display: inline-block;
    will-change: transform, opacity, filter;
    transform-origin: center center;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    margin: 0;
    line-height: 1.2;
  }

  /* Outgoing transition animation styling */
  #utility-bar-{{ section.id }} .announcement-bar-slider--fade-out-next .announcement-bar__message,
  #utility-bar-{{ section.id }} .announcement-bar-slider--fade-out-previous .announcement-bar__message {
    animation: ab-exit 420ms cubic-bezier(.4, 0, .6, 1) both;
  }

  /* Incoming transition animation styling */
  #utility-bar-{{ section.id }} .announcement-bar-slider--fade-in-next .announcement-bar__message,
  #utility-bar-{{ section.id }} .announcement-bar-slider--fade-in-previous .announcement-bar__message,
  #utility-bar-{{ section.id }} .slider__slide[aria-hidden="false"] .announcement-bar__message,
  #utility-bar-{{ section.id }} .slider__slide.is-active .announcement-bar__message,
  #utility-bar-{{ section.id }} .slider__slide.active .announcement-bar__message {
    animation: ab-enter 500ms cubic-bezier(.16, 1, .3, 1) both;
  }

  @keyframes ab-exit {
    0%   { opacity: 1;  transform: translateY(0)     rotateX(0deg);   filter: blur(0px); }
    60%  { opacity: .4; transform: translateY(-4px)  rotateX(30deg);  filter: blur(1px); }
    100% { opacity: 0;  transform: translateY(-10px) rotateX(60deg);  filter: blur(3px); }
  }

  @keyframes ab-enter {
    0%   { opacity: 0;  transform: translateY(14px)  rotateX(-50deg); filter: blur(3px); }
    55%  { opacity: 1;  transform: translateY(-2px)  rotateX(4deg);   filter: blur(0px); }
    75%  {              transform: translateY(1px)   rotateX(-1deg); }
    100% { opacity: 1;  transform: translateY(0)     rotateX(0deg);   filter: blur(0px); }
  }

  #utility-bar-{{ section.id }} .announcement-bar__link {
    text-decoration: none;
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    transition: transform 0.20s ease-in-out;
  }

  #utility-bar-{{ section.id }} .announcement-bar__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
    border-radius: 2px;
  }

  {%- if request.design_mode -%}
  #utility-bar-{{ section.id }} .announcement-bar-slider .slider__slide[aria-hidden='true'] {
    visibility: hidden;
  }
  {%- endif -%}
</style>

<div
  id="utility-bar-{{ section.id }}"
  class="utility-bar color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator and section.blocks.size > 0 %} utility-bar--bottom-border{% elsif section.settings.show_line_separator and section.settings.show_social and social_icons %} utility-bar--bottom-border-social-only{% endif %}{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header-localization{% endif %}"
>
  <div class="{% if section.settings.section_width == 'page' %}page-width{% endif %} utility-bar__inner">

    <!-- LEFT: Social Icons -->
    <div class="utility-bar__left">
      {%- if section.settings.show_social and social_icons -%}
        <span class="small-hide medium-hide">
          {%- render 'social-icons' -%}
        </span>
      {%- endif -%}
    </div>

    <!-- CENTER: Announcements -->
    <div class="utility-bar__center">
      {%- if section.blocks.size == 1 -%}
        <div
          class="announcement-bar"
          role="region"
          aria-label="{{ 'sections.header.announcement' | t }}"
          {{ section.blocks.first.shopify_attributes }}
        >
          {%- assign b = section.blocks.first.settings -%}
          {%- if b.text != blank -%}
            {%- if b.link != blank -%}
              <a href="{{ b.link }}" class="announcement-bar__link focus-inset" aria-label="{{ b.text | strip_html }}">
            {%- endif -%}
              <p class="announcement-bar__message"
                style="
                  font-size: {{ b.font_size }};
                  font-weight: {{ b.font_weight }};
                  letter-spacing: {% if b.letter_spacing == 'tight' %}-0.03em{% elsif b.letter_spacing == 'loose' %}0.08em{% else %}normal{% endif %};
                  text-transform: {{ b.text_transform }};
                "
              >
                {{ b.text | escape }}
              </p>
            {%- if b.link != blank -%}
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- elsif section.blocks.size > 1 -%}
        <slideshow-component
          class="announcement-bar"
          role="region"
          aria-roledescription="{{ 'sections.announcements.carousel' | t }}"
          aria-label="{{ 'sections.announcements.announcement_bar' | t }}"
        >
          <div class="announcement-bar-slider slider-buttons">
            <button
              type="button"
              class="slider-button slider-button--prev{% unless section.settings.show_slider_buttons %} hidden{% endunless %}"
              name="previous"
              aria-label="{{ 'sections.announcements.previous_announcement' | t }}"
              aria-controls="Slider-{{ section.id }}"
              {% unless section.settings.show_slider_buttons %}aria-hidden="true" tabindex="-1"{% endunless %}
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
            <div
              class="grid grid--1-col slider slider--everywhere"
              id="Slider-{{ section.id }}"
              aria-live="polite"
              aria-atomic="true"
              data-autoplay="{{ section.settings.auto_rotate }}"
              data-speed="{{ section.settings.change_slides_speed }}"
            >
              {%- for block in section.blocks -%}
                {%- assign b = block.settings -%}
                <div
                  class="slideshow__slide slider__slide grid__item"
                  id="Slide-{{ section.id }}-{{ forloop.index }}"
                  aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if b.text != blank -%}
                    {%- if b.link != blank -%}
                      <a href="{{ b.link }}" 
                         class="announcement-bar__link focus-inset" 
                         aria-label="{{ b.text | strip_html }}"
                         tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                      >
                    {%- endif -%}
                      <p class="announcement-bar__message"
                        style="
                          font-size: {{ b.font_size }};
                          font-weight: {{ b.font_weight }};
                          letter-spacing: {% if b.letter_spacing == 'tight' %}-0.03em{% elsif b.letter_spacing == 'loose' %}0.08em{% else %}normal{% endif %};
                          text-transform: {{ b.text_transform }};
                        "
                      >
                        {{ b.text | escape }}
                      </p>
                    {%- if b.link != blank -%}
                      </a>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
            <button
              type="button"
              class="slider-button slider-button--next{% unless section.settings.show_slider_buttons %} hidden{% endunless %}"
              name="next"
              aria-label="{{ 'sections.announcements.next_announcement' | t }}"
              aria-controls="Slider-{{ section.id }}"
              {% unless section.settings.show_slider_buttons %}aria-hidden="true" tabindex="-1"{% endunless %}
            >
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>
        </slideshow-component>
        {%- if request.design_mode -%}
          <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
          <style>
            .announcement-bar-slider .slider__slide[aria-hidden='true'] {
              visibility: hidden;
            }
          </style>
        {%- endif -%}
      {%- endif -%}
    </div>

    <!-- RIGHT: Country/Language Localization selectors -->
    <div class="utility-bar__right">
      <div class="localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'AnnouncementCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="AnnouncementCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide">
            {%- form 'localization', id: 'AnnouncementLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="AnnouncementLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const utilityBar = document.querySelector('#utility-bar-{{ section.id }}');
    if (!utilityBar) return;

    const sliderContainer = utilityBar.querySelector('.announcement-bar-slider');
    const slides = utilityBar.querySelectorAll('.slider__slide');
    if (!sliderContainer || slides.length <= 1) return;

    let prevActiveIndex = Array.from(slides).findIndex(slide => slide.getAttribute('aria-hidden') === 'false');
    if (prevActiveIndex === -1) prevActiveIndex = 0;

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === 'attributes' && mutation.attributeName === 'aria-hidden') {
          const currentSlide = mutation.target;
          const isHidden = currentSlide.getAttribute('aria-hidden') === 'true';

          if (!isHidden) {
            const slidesArray = Array.from(slides);
            const currentIdx = slidesArray.indexOf(currentSlide);

            if (currentIdx !== prevActiveIndex) {
              const isNext = currentIdx > prevActiveIndex || (currentIdx === 0 && prevActiveIndex === slidesArray.length - 1);
              const direction = isNext ? 'next' : 'previous';

              // Reset transition states on container to trigger clean CSS keyframes
              sliderContainer.classList.remove(
                'announcement-bar-slider--fade-in-next',
                'announcement-bar-slider--fade-in-previous',
                'announcement-bar-slider--fade-out-next',
                'announcement-bar-slider--fade-out-previous'
              );

              sliderContainer.classList.add(`announcement-bar-slider--fade-out-${direction}`);
              
              // Force layout reflow to restart CSS animations smoothly
              void sliderContainer.offsetWidth;

              sliderContainer.classList.add(`announcement-bar-slider--fade-in-${direction}`);

              prevActiveIndex = currentIdx;
            }
          }
        }
      });
    });

    slides.forEach((slide) => {
      observer.observe(slide, { attributes: true });
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page", "label": "Page" },
        { "value": "full", "label": "Full" }
      ],
      "default": "page"
    },
    {
      "type": "range",
      "id": "bar_padding",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 10
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-bar.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.announcement-bar.settings.change_slides_speed.label",
      "default": 5
    },
    {
      "type": "header",
      "content": "t:sections.announcement-bar.settings.heading_utilities.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.announcement-bar.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.announcement-bar.settings.show_social.label",
      "info": "t:sections.announcement-bar.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "show_slider_buttons",
      "default": true,
      "label": "Show announcement slider buttons"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_country_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_language_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_language_selector.info"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "header",
          "content": "Typography Settings"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font size",
          "options": [
            { "value": "1.0rem", "label": "Extra Small" },
            { "value": "1.2rem", "label": "Small" },
            { "value": "1.3rem", "label": "Medium" },
            { "value": "1.4rem", "label": "Large" },
            { "value": "1.6rem", "label": "Extra Large" }
          ],
          "default": "1.3rem"
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font weight",
          "options": [
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Normal" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi-bold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "400"
        },
        {
          "type": "select",
          "id": "letter_spacing",
          "label": "Letter spacing",
          "options": [
            { "value": "tight", "label": "Tight" },
            { "value": "normal", "label": "Normal" },
            { "value": "loose", "label": "Loose" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text transform",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ],
          "default": "uppercase"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}