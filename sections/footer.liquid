{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }

  /* ?? Email Signup Strip ?? */
  .footer-signup-strip {
    background-color: {{ section.settings.signup_bg_color }};
    padding: {{ section.settings.signup_padding_top | times: 0.75 | round: 0 }}px 20px {{ section.settings.signup_padding_bottom | times: 0.75 | round: 0 }}px;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .footer-signup-strip {
      padding-top: {{ section.settings.signup_padding_top }}px;
      padding-bottom: {{ section.settings.signup_padding_bottom }}px;
    }
  }

  .footer-signup-strip__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
  }

  .footer-signup-strip__content {
    flex-shrink: 0;
    max-width: 400px;
  }

  .footer-signup-strip__heading {
    font-size: {{ section.settings.signup_heading_size | times: 0.75 | round: 0 }}px;
    font-weight: 600;
    margin: 0 0 {{ section.settings.text_spacing }}px 0;
    color: {{ section.settings.signup_text_color }};
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .footer-signup-strip__heading {
      font-size: {{ section.settings.signup_heading_size }}px;
    }
  }

  .footer-signup-strip__subtext {
    font-size: {{ section.settings.signup_subtext_size }}px;
    margin: 0;
    color: {{ section.settings.signup_text_color }};
    opacity: 0.8;
    line-height: 1.4;
  }

  .footer-signup-strip__form-wrapper {
    flex-shrink: 0;
    width: {{ section.settings.email_field_width }}%;
    max-width: 600px;
    min-width: 0;
    box-sizing: border-box;
  }

  .footer-signup-strip__form {
    display: flex;
    gap: 0;
    width: 100%;
    box-sizing: border-box;
  }

  .footer-signup-strip__input {
    flex: 1 1 0%;
    min-width: 0;
    width: 0;
    padding: 14px 24px;
    border: 1px solid rgba(18, 18, 18, 0.2);
    border-right: none;
    border-radius: 50px 0 0 50px;
    font-size: 15px;
    outline: none;
    background-color: #ffffff;
    box-sizing: border-box;
  }

  .footer-signup-strip__input:focus {
    border-color: #121212;
  }

  .footer-signup-strip__button {
    padding: 14px 24px;
    background-color: {{ section.settings.signup_button_color }};
    color: {{ section.settings.signup_button_text_color }};
    border: none;
    border-radius: 0 50px 50px 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .footer-signup-strip__button:hover {
    opacity: 0.85;
  }

  .footer-signup-strip__button svg {
    width: 20px;
    height: 20px;
  }

  .footer-signup-strip__success {
    color: #008060;
    margin-top: 8px;
    font-size: 13px;
  }

  .footer-signup-strip__error {
    color: #D82C0D;
    margin-top: 8px;
    font-size: 13px;
  }

  /* ?? Main Footer Dark Section ?? */
  .footer-main {
    background-color: {{ section.settings.main_bg_color }};
    color: {{ section.settings.main_text_color }};
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 20px {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-main {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .footer-main__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
  }

  .footer-main__column {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-main__column-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: {{ section.settings.main_text_color }};
  }

  .footer-main__link {
    color: {{ section.settings.main_text_color }};
    text-decoration: none;
    font-size: 14px;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .footer-main__link:hover {
    opacity: 1;
  }

  .footer-main__social {
    display: flex;
    gap: 16px;
    margin-top: 8px;
  }

  .footer-main__social-link {
    color: {{ section.settings.main_text_color }};
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-main__social-link:hover {
    opacity: 0.7;
  }

  .footer-main__social-link svg {
    width: 24px;
    height: 24px;
  }

  /* ?? Footer Bottom Bar ?? */
  .footer-bottom {
    background-color: {{ section.settings.main_bg_color }};
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: {{ section.settings.footer_bottom_top_spacing | times: 0.75 | round: 0 }}px 20px 0;
  }

  @media screen and (min-width: 750px) {
    .footer-bottom {
      padding-top: {{ section.settings.footer_bottom_top_spacing }}px;
    }
  }

  .footer-bottom__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding-bottom: 16px;
  }

  .footer-bottom__localization {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .footer-bottom__localization-label {
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 4px;
    font-size: 1.1rem;
  }

  .footer-bottom__follow {
    display: flex;
    align-items: center;
  }

  .footer-bottom__payment {
    display: flex;
    align-items: center;
    flex: 1;
  }

  .footer-bottom__payment--left   { justify-content: flex-start; }
  .footer-bottom__payment--center { justify-content: center; }
  .footer-bottom__payment--right  { justify-content: flex-end; }

  .footer-bottom__payment .list-payment {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ?? Copyright bar ?? */
  .footer-bottom__copyright {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 12px;
    padding: 14px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.55);
    justify-content: {{ section.settings.copyright_alignment }};
  }

  .footer-bottom__copyright-item {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-bottom__policy-link {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-bottom__policy-link:hover {
    color: #ffffff;
  }

  /* ?? Scroll-to-top divider ?? */
  .footer-scroll-divider-wrap {
    background-color: {{ section.settings.main_bg_color }};
    padding: {{ section.settings.scroll_divider_padding | times: 0.75 | round: 0 }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .footer-scroll-divider-wrap {
      padding-top: {{ section.settings.scroll_divider_padding }}px;
      padding-bottom: {{ section.settings.scroll_divider_padding }}px;
    }
  }

  .footer-scroll-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .footer-scroll-divider__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to var(--line-dir, right),
      transparent,
      rgba(255, 255, 255, 0.12) 40%,
      rgba(255, 255, 255, 0.18)
    );
  }

  .footer-scroll-divider__line:first-child {
    --line-dir: right;
    max-width: 480px;
  }

  .footer-scroll-divider__line:last-child {
    --line-dir: left;
    max-width: 480px;
  }

  .footer-scroll-top {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: {{ section.settings.main_bg_color }};
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
    margin: -20px 24px;
    position: relative;
    z-index: 1;
  }

  .footer-scroll-top:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.45);
    color: #ffffff;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
  }

  .footer-scroll-top:active {
    transform: translateY(-1px) scale(0.95);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .footer-scroll-top svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  /* ?? Scroll divider visibility ?? */
    {%- if section.settings.show_scroll_divider == false -%}
      .footer-scroll-divider { display: none; }
    {%- endif -%}

    .footer-main {
      /* spacing already defined above; override padding-bottom here */
      padding-bottom: {{ section.settings.footer_main_bottom_spacing | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .footer-main {
        padding-bottom: {{ section.settings.footer_main_bottom_spacing }}px;
      }
    }

  /* ?? Responsive ?? */
  @media screen and (max-width: 749px) {
    .footer-signup-strip__container {
      flex-direction: column;
      align-items: stretch;
      gap: 20px;
    }

    .footer-signup-strip__content {
      max-width: 100%;
    }

    .footer-signup-strip__form-wrapper {
      width: 100%;
      max-width: 100%;
    }

    .footer-signup-strip__form {
      width: 100%;
    }

    .footer-signup-strip__input {
      min-width: 0;
      width: 0;
      flex: 1 1 0%;
      padding: 12px 16px;
      font-size: 14px;
    }

    .footer-signup-strip__button {
      padding: 12px 18px;
      flex-shrink: 0;
    }

    .footer-main__container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-bottom__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .footer-bottom__payment {
      width: 100%;
    }

    .footer-bottom__copyright {
      justify-content: center;
    }
  }
{%- endstyle -%}



{%- comment -%} Section 1: Email Signup Strip {%- endcomment -%}
<footer class="footer" role="contentinfo">
  <div class="footer-signup-strip">
    <div class="footer-signup-strip__container">
      <div class="footer-signup-strip__content">
        <h2 class="footer-signup-strip__heading">{{ section.settings.signup_heading }}</h2>
        {%- if section.settings.signup_subtext != blank -%}
          <p class="footer-signup-strip__subtext">{{ section.settings.signup_subtext }}</p>
        {%- endif -%}
      </div>

      <div class="footer-signup-strip__form-wrapper">
        {%- form 'customer', id: 'FooterSignupForm', class: 'footer-signup-strip__form-container' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer-signup-strip__form">
            <input
              id="FooterSignupEmail"
              type="email"
              name="contact[email]"
              class="footer-signup-strip__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {%- if form.errors %}
                aria-invalid="true"
                aria-describedby="FooterSignupError"
              {%- elsif form.posted_successfully? %}
                aria-describedby="FooterSignupSuccess"
              {%- endif %}
              placeholder="{{ section.settings.signup_placeholder }}"
              required
            >
            <button
              type="submit"
              class="footer-signup-strip__button"
              name="commit"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </div>

          {%- if form.errors -%}
            <small id="FooterSignupError" class="footer-signup-strip__error">
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <p id="FooterSignupSuccess" class="footer-signup-strip__success" tabindex="-1" autofocus>
              {{ section.settings.signup_success_message }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>

  {%- comment -%} Section 2: Main Footer {%- endcomment -%}
  <div class="footer-main">
    <div class="footer-main__container">

      <div class="footer-main__column">
        <h3 class="footer-main__column-title">{{ section.settings.column_1_title }}</h3>
        {%- if section.settings.column_1_link_1_text != blank -%}
          <a href="{{ section.settings.column_1_link_1_url }}" class="footer-main__link">{{ section.settings.column_1_link_1_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_1_link_2_text != blank -%}
          <a href="{{ section.settings.column_1_link_2_url }}" class="footer-main__link">{{ section.settings.column_1_link_2_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_1_link_3_text != blank -%}
          <a href="{{ section.settings.column_1_link_3_url }}" class="footer-main__link">{{ section.settings.column_1_link_3_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_1_link_4_text != blank -%}
          <a href="{{ section.settings.column_1_link_4_url }}" class="footer-main__link">{{ section.settings.column_1_link_4_text }}</a>
        {%- endif -%}
      </div>

      <div class="footer-main__column">
        <h3 class="footer-main__column-title">{{ section.settings.column_2_title }}</h3>
        {%- if section.settings.column_2_link_1_text != blank -%}
          <a href="{{ section.settings.column_2_link_1_url }}" class="footer-main__link">{{ section.settings.column_2_link_1_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_2_link_2_text != blank -%}
          <a href="{{ section.settings.column_2_link_2_url }}" class="footer-main__link">{{ section.settings.column_2_link_2_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_2_link_3_text != blank -%}
          <a href="{{ section.settings.column_2_link_3_url }}" class="footer-main__link">{{ section.settings.column_2_link_3_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_2_link_4_text != blank -%}
          <a href="{{ section.settings.column_2_link_4_url }}" class="footer-main__link">{{ section.settings.column_2_link_4_text }}</a>
        {%- endif -%}
      </div>

      <div class="footer-main__column">
        <h3 class="footer-main__column-title">{{ section.settings.column_3_title }}</h3>
        {%- if section.settings.column_3_link_1_text != blank -%}
          <a href="{{ section.settings.column_3_link_1_url }}" class="footer-main__link">{{ section.settings.column_3_link_1_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_3_link_2_text != blank -%}
          <a href="{{ section.settings.column_3_link_2_url }}" class="footer-main__link">{{ section.settings.column_3_link_2_text }}</a>
        {%- endif -%}
        {%- if section.settings.column_3_link_3_text != blank -%}
          <a href="{{ section.settings.column_3_link_3_url }}" class="footer-main__link">{{ section.settings.column_3_link_3_text }}</a>
        {%- endif -%}
      </div>

      <div class="footer-main__column">
        <h3 class="footer-main__column-title">{{ section.settings.social_column_title }}</h3>
        <div class="footer-main__social">
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer-main__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-main__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="footer-main__social-link" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>

  {%- comment -%} Scroll-to-top divider {%- endcomment -%}
<div class="footer-scroll-divider-wrap">
  <div class="footer-scroll-divider">
    <div class="footer-scroll-divider__line"></div>
    <button
      class="footer-scroll-top"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
      aria-label="Back to top"
      title="Back to top"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    <div class="footer-scroll-divider__line"></div>
  </div>
</div>

  {%- comment -%} Bottom bar: localization, payment, Follow on Shop, copyright {%- endcomment -%}
  <div class="footer-bottom">
    <div class="footer-bottom__inner page-width">

      <div class="footer-bottom__localization">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body footer-bottom__localization-label" id="FooterCountryLabel">
                  {{ 'localization.country_label' | t }}
                </h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body footer-bottom__localization-label" id="FooterLanguageLabel">
                  {{ 'localization.language_label' | t }}
                </h2>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
        <div class="footer-bottom__follow">
          {{ shop | login_button: action: 'follow' }}
        </div>
      {%- endif -%}

      {%- if section.settings.payment_enable -%}
        <div class="footer-bottom__payment footer-bottom__payment--{{ section.settings.payment_alignment }}">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

    </div>

    <div class="footer-bottom__copyright page-width">
      <small class="footer-bottom__copyright-item">{{ section.settings.copyright_text }}</small>
      {%- if section.settings.show_policy -%}
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <small class="footer-bottom__copyright-item">
              <a href="{{ policy.url }}" class="footer-bottom__policy-link">{{ policy.title | escape }}</a>
            </small>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</footer>

