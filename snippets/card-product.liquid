{% comment %}
  Renders an enhanced product card with Quick Look + Add to Cart hover actions

  Accepts:
  - card_product: {Object} Product Liquid object (optional)
  - media_aspect_ratio: {String} Values are "square", "portrait", "adapt". Default: "square"
  - image_shape: {String} Image mask shape (optional)
  - show_secondary_image: {Boolean} Default: false
  - show_vendor: {Boolean} Default: false
  - show_rating: {Boolean} Default: false
  - extend_height: {Boolean} Default: true
  - lazy_load: {Boolean} Default: true
  - skip_styles: {Boolean} Default: false
  - quick_add: {Boolean}
  - section_id: {String}
  - horizontal_class: {Boolean} Default: false
  - horizontal_quick_add: {Boolean} Default: false
  - placeholder_image: {String} Default: 'product-apparel-2'
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}

  <style>
    /* ── Card Base ──────────────────────────────────────────────── */
    .product-card-wrapper { position: relative; }

    .card--enhanced {
      border-radius: 12px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 1px 4px rgba(0,0,0,.06);
      transition: box-shadow .28s ease, transform .28s ease;
      /* NOTE: will-change intentionally omitted — it creates a stacking
         context that would trap position:fixed children (the QL modal). */
    }
    .card--enhanced:hover {
      box-shadow: 0 8px 28px rgba(0,0,0,.13);
      transform: translateY(-3px);
    }

    /* ── Image area ─────────────────────────────────────────────── */
    .card--enhanced .card__media-wrapper {
      position: relative;
      overflow: hidden;
      border-radius: 12px 12px 0 0;
    }
    .card--enhanced .card__media img {
      transition: transform .5s cubic-bezier(.25,.46,.45,.94);
    }
    .card--enhanced:hover .card__media img {
      transform: scale(1.06);
    }

    /* ── Hover action bar ───────────────────────────────────────── */
    .card__hover-actions {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      display: flex;
      gap: 8px;
      padding: 12px;
      background: linear-gradient(to top, rgba(0,0,0,.45) 0%, transparent 100%);
      transform: translateY(100%);
      transition: transform .3s cubic-bezier(.34,1.2,.64,1);
      z-index: 3;
    }
    .card--enhanced:hover .card__hover-actions { transform: translateY(0); }

    .card__hover-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 10px 14px;
      border: none;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .4px;
      cursor: pointer;
      text-decoration: none;
      transition: background .18s ease, transform .15s ease;
      white-space: nowrap;
    }
    .card__hover-btn:active { transform: scale(.97); }

    .card__hover-btn--quicklook {
      background: rgba(255,255,255,.92);
      color: #111;
      backdrop-filter: blur(6px);
    }
    .card__hover-btn--quicklook:hover { background: #fff; }

    .card__hover-btn--atc { background: #111; color: #fff; }
    .card__hover-btn--atc:hover { background: #333; }
    .card__hover-btn--atc.sold-out {
      background: rgba(255,255,255,.5);
      color: rgba(255,255,255,.7);
      cursor: not-allowed;
    }
    .card__hover-btn svg { flex-shrink: 0; }

    /* ── Badges ─────────────────────────────────────────────────── */
    .card__badge-stack {
      position: absolute;
      top: 12px; left: 12px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      z-index: 2;
    }
    .badge--pill {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .5px;
      text-transform: uppercase;
    }
    .badge--sale    { background: #e63946; color: #fff; }
    .badge--soldout { background: #555;    color: #fff; }

    /* ── Card info ──────────────────────────────────────────────── */
    .card--enhanced .card__info { padding: 14px 16px 16px; }

    .card--enhanced .card__vendor {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .8px;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 4px;
    }
    .card--enhanced .card__title a {
      font-size: 15px;
      font-weight: 600;
      color: #111;
      text-decoration: none;
      line-height: 1.35;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card--enhanced .card__title a:hover { color: #333; }

    .card--enhanced .card__pricing {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-top: 8px;
    }
    .card--enhanced .price--current {
      font-size: 16px;
      font-weight: 700;
      color: #111;
    }
    .card--enhanced .price--compare {
      font-size: 13px;
      color: #aaa;
      text-decoration: line-through;
    }
    .card--enhanced .price--sale { color: #e63946; }

    /* ── Color swatches ─────────────────────────────────────────── */
    .card__color-swatches {
      display: flex;
      gap: 5px;
      margin-top: 10px;
      flex-wrap: wrap;
      align-items: center;
    }
    .color-swatch {
      width: 18px; height: 18px;
      border-radius: 50%;
      border: 2px solid transparent;
      cursor: pointer;
      transition: transform .15s ease, border-color .15s ease;
      box-shadow: 0 0 0 1px rgba(0,0,0,.12);
    }
    .color-swatch:hover,
    .color-swatch.active { border-color: #111; transform: scale(1.2); }

    /* ── Rating ─────────────────────────────────────────────────── */
    .card__rating-row {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-top: 6px;
    }
    .card__stars { display: flex; gap: 1px; }
    .card__stars svg { color: #f4a261; }
    .card__rating-count { font-size: 12px; color: #888; }

    /* ════════════════════════════════════════════════════════════
       QUICK LOOK MODAL
       The overlay is moved to <body> via JS so it is NEVER inside
       a CSS-transformed ancestor (which would break position:fixed).
    ══════════════════════════════════════════════════════════════ */

    /* Default: hidden. Do NOT use the HTML `hidden` attribute — many
       browsers apply [hidden]{display:none!important} which overrides
       the .is-open rule below and permanently traps the modal. */
    .ql-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.5);
      backdrop-filter: blur(4px);
      z-index: 9998;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    /* Only the class toggle controls visibility */
    .ql-overlay.is-open { display: flex; }

    .ql-modal {
      background: #fff;
      border-radius: 16px;
      width: 100%;
      max-width: 820px;
      max-height: 90vh;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
      box-shadow: 0 24px 64px rgba(0,0,0,.22);
      position: relative;
      animation: ql-up .28s cubic-bezier(.34,1.2,.64,1);
    }
    @keyframes ql-up {
      from { opacity:0; transform: translateY(20px) scale(.97); }
      to   { opacity:1; transform: translateY(0)    scale(1);   }
    }

    .ql-close {
      position: absolute;
      top: 14px; right: 14px;
      width: 32px; height: 32px;
      background: rgba(0,0,0,.07);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: background .15s ease;
    }
    .ql-close:hover { background: rgba(0,0,0,.15); }

    .ql-image {
      background: #f6f6f6;
      overflow: hidden;
      min-height: 420px;
    }
    .ql-image img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }

    .ql-details {
      padding: 32px 28px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .ql-vendor {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #999;
    }
    .ql-title {
      font-size: 20px;
      font-weight: 700;
      color: #111;
      line-height: 1.3;
      margin: 0;
    }
    .ql-price-row { display: flex; align-items: baseline; gap: 10px; }
    .ql-price-current { font-size: 22px; font-weight: 800; color: #111; }
    .ql-price-current.on-sale { color: #e63946; }
    .ql-price-compare { font-size: 16px; color: #bbb; text-decoration: line-through; }

    .ql-description {
      font-size: 14px;
      color: #555;
      line-height: 1.65;
      border-top: 1px solid #f0f0f0;
      padding-top: 16px;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .ql-section-label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .6px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 8px;
    }
    .ql-swatches { display: flex; gap: 8px; flex-wrap: wrap; }
    .ql-swatch {
      width: 28px; height: 28px;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid transparent;
      box-shadow: 0 0 0 1px rgba(0,0,0,.14);
      transition: transform .15s ease, border-color .15s ease;
    }
    .ql-swatch:hover,
    .ql-swatch.active { border-color: #111; transform: scale(1.18); }

    .ql-atc-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 20px;
      background: #111;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: .3px;
      cursor: pointer;
      transition: background .18s ease, transform .15s ease;
      width: 100%;
      margin-top: 4px;
    }
    .ql-atc-btn:hover { background: #333; }
    .ql-atc-btn:active { transform: scale(.98); }
    .ql-atc-btn.disabled { background: #ddd; color: #aaa; cursor: not-allowed; }
    .ql-atc-btn.added {
      background: #2d6a4f;
      pointer-events: none;
    }
    .ql-atc-btn.go-to-cart {
      background: #111;
      pointer-events: auto;
      text-decoration: none;
      display: flex;
    }
    .ql-atc-btn.go-to-cart:hover { background: #333; }

    /* Card hover ATC — "Go to Cart" state */
    .card__hover-btn--atc.added-state {
      background: #2d6a4f;
      pointer-events: none;
    }
    .card__hover-btn--atc.go-to-cart-state {
      background: #111;
      pointer-events: auto;
    }

    .ql-full-link {
      display: block;
      text-align: center;
      font-size: 13px;
      color: #555;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color .15s ease;
    }
    .ql-full-link:hover { color: #111; }

    .ql-trust-badges {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 14px;
      background: #f9f9f9;
      border-radius: 10px;
      margin-top: 4px;
    }
    .ql-trust-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12.5px;
      color: #444;
      font-weight: 500;
    }
    .ql-trust-badge svg { flex-shrink: 0; color: #2d6a4f; }

    /* ── Mobile ─────────────────────────────────────────────────── */
    @media (max-width: 749px) {
      .ql-modal { grid-template-columns: 1fr; max-height: 92vh; }
      .ql-image { min-height: 220px; max-height: 260px; }
      .ql-details { padding: 20px 18px; gap: 12px; }
      .card__hover-actions { padding: 8px; }
      .card__hover-btn { padding: 9px 10px; font-size: 12px; }
    }

    body.ql-no-scroll { overflow: hidden; }
  </style>
{%- endunless -%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.8
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif

    assign is_on_sale = false
    if card_product.compare_at_price > card_product.price and card_product.available
      assign is_on_sale = true
    endif

    assign color_option = nil
    for option in card_product.options_with_values
      assign option_lc = option.name | downcase
      if option_lc == 'color' or option_lc == 'colour'
        assign color_option = option
        break
      endif
    endfor
  -%}

  <div class="card-wrapper product-card-wrapper underline-links-hover">
    <div
      class="card card--enhanced{% if extend_height %} card--extend-height{% endif %}{% if horizontal_class %} card--horizontal{% endif %}"
      data-product-id="{{ card_product.id }}"
    >

      <!-- Image + hover actions -->
      <div
        class="card__media-wrapper"
        style="padding-top: {{ 1 | divided_by: ratio | times: 100 }}%; position: relative;"
      >

        <!-- Badges -->
        <div class="card__badge-stack">
          {%- if card_product.available == false -%}
            <span class="badge--pill badge--soldout">Sold Out</span>
          {%- elsif is_on_sale -%}
            <span class="badge--pill badge--sale">Sale</span>
          {%- endif -%}
        </div>

        {%- if card_product.featured_media -%}
          <div class="card__media" style="position:absolute;inset:0;">
            <div class="media media--transparent media--hover-effect" style="height:100%;">
              {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
              <img
                srcset="
                  {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 940 -%}{{ card_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                  {%- if card_product.featured_media.width >= 1066 -%}{{ card_product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                  {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
                "
                src="{{ card_product.featured_media | image_url: width: 533 }}"
                sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                alt="{{ card_product.featured_media.alt | escape }}"
                class="motion-reduce"
                {% unless lazy_load == false %}loading="lazy"{% endunless %}
                width="{{ card_product.featured_media.width }}"
                height="{{ card_product.featured_media.height }}"
                style="width:100%;height:100%;object-fit:cover;"
              >
              {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}

              {%- if card_product.media[1] != null and show_secondary_image -%}
                <img
                  srcset="
                    {%- if card_product.media[1].width >= 165 -%}{{ card_product.media[1] | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if card_product.media[1].width >= 533 -%}{{ card_product.media[1] | image_url: width: 533 }} 533w,{%- endif -%}
                    {%- if card_product.media[1].width >= 1066 -%}{{ card_product.media[1] | image_url: width: 1066 }} 1066w,{%- endif -%}
                    {{ card_product.media[1] | image_url }} {{ card_product.media[1].width }}w
                  "
                  src="{{ card_product.media[1] | image_url: width: 533 }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ card_product.media[1].alt | escape }}"
                  class="motion-reduce"
                  loading="lazy"
                  width="{{ card_product.media[1].width }}"
                  height="{{ card_product.media[1].height }}"
                  style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;"
                >
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Hover Action Bar -->
        <div class="card__hover-actions">

          <!-- Quick Look button -->
          <button
            class="card__hover-btn card__hover-btn--quicklook"
            type="button"
            data-ql-trigger
            data-product-title="{{ card_product.title | escape }}"
            data-product-url="{{ card_product.url }}"
            data-product-vendor="{{ card_product.vendor | escape }}"
            data-product-description="{{ card_product.description | strip_html | truncatewords: 60 | escape }}"
            data-product-price="{{ card_product.price | money }}"
            data-product-compare-price="{% if is_on_sale %}{{ card_product.compare_at_price | money }}{% endif %}"
            data-product-available="{{ card_product.available }}"
            data-product-image="{{ card_product.featured_media | image_url: width: 800 }}"
            data-product-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
            data-product-on-sale="{{ is_on_sale }}"
            data-product-colors="{%- if color_option -%}{{ color_option.values | join: '|' }}{%- endif -%}"
            aria-label="Quick look at {{ card_product.title | escape }}"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            Quick Look
          </button>

          <!-- Add to Cart / Options / Sold Out -->
          {%- if card_product.variants_count > 1 -%}
            <a
              href="{{ card_product.url }}"
              class="card__hover-btn card__hover-btn--atc"
              aria-label="Choose options for {{ card_product.title | escape }}"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
                <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
              </svg>
              Options
            </a>
          {%- elsif card_product.available -%}
            <button
              class="card__hover-btn card__hover-btn--atc js-quick-atc"
              type="button"
              data-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
              aria-label="Add {{ card_product.title | escape }} to cart"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
                <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
              </svg>
              Add to Cart
            </button>
          {%- else -%}
            <button class="card__hover-btn card__hover-btn--atc sold-out" type="button" disabled>
              Sold Out
            </button>
          {%- endif -%}

        </div>
      </div><!-- /.card__media-wrapper -->

      <!-- Card Info -->
      <div class="card__info">
        {%- if show_vendor and card_product.vendor != blank -%}
          <div class="card__vendor">{{ card_product.vendor }}</div>
        {%- endif -%}

        <h3 class="card__title">
          <a href="{{ card_product.url }}" class="full-unstyled-link">
            {{ card_product.title | escape }}
          </a>
        </h3>

        <!-- Star rating -->
        {%- if show_rating and card_product.metafields.reviews.rating.value != blank -%}
          {%- liquid
            assign rating_val   = card_product.metafields.reviews.rating.value.rating | round
            assign rating_count = card_product.metafields.reviews.rating_count
          -%}
          <div class="card__rating-row">
            <div class="card__stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                {%- if i <= rating_val -%}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- else -%}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <span class="card__rating-count">({{ rating_count }})</span>
          </div>
        {%- endif -%}

        <!-- Price -->
        <div class="card__pricing">
          {%- if is_on_sale -%}
            <span class="price--current price--sale">{{ card_product.price | money }}</span>
            <span class="price--compare">{{ card_product.compare_at_price | money }}</span>
          {%- elsif card_product.available == false -%}
            <span class="price--current" style="color:#aaa;">{{ card_product.price | money }}</span>
          {%- else -%}
            <span class="price--current">{{ card_product.price | money }}</span>
          {%- endif -%}
        </div>

        <!-- Color swatches -->
        {%- if color_option -%}
          <div class="card__color-swatches">
            {%- for color_val in color_option.values limit: 6 -%}
              {%- assign color_handle = color_val | handle -%}
              <span
                class="color-swatch{% if forloop.first %} active{% endif %}"
                style="background-color: {{ color_handle }};"
                title="{{ color_val | escape }}"
                aria-label="{{ color_val | escape }}"
              ></span>
            {%- endfor -%}
            {%- if color_option.values.size > 6 -%}
              <span style="font-size:11px;color:#888;">+{{ color_option.values.size | minus: 6 }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div><!-- /.card__info -->

    </div><!-- /.card--enhanced -->
  </div><!-- /.card-wrapper -->

{%- else -%}
  {%- liquid
    assign ratio = 1
    if media_aspect_ratio == 'portrait'
      assign ratio = 0.8
    endif
  -%}
  <div class="card-wrapper product-card-wrapper underline-links-hover">
    <div class="card card--enhanced">
      <div class="card__media-wrapper" style="padding-top: {{ 1 | divided_by: ratio | times: 100 }}%; position: relative;">
        <div style="position:absolute;inset:0;background:#f5f5f5;">
          {%- if placeholder_image -%}
            {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
          {%- else -%}
            {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
      <div class="card__info">
        <h3 class="card__title">
          <a role="link" aria-disabled="true" class="full-unstyled-link">{{ 'onboarding.product_title' | t }}</a>
        </h3>
        <div class="card__pricing">
          <span class="price--current">$0.00</span>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}


<!-- ════════════════════════════════════════════════════════════════
     QUICK LOOK MODAL — rendered once (first card only, skip_styles=false)
     IMPORTANT: The JS below immediately moves this node to <body> so it
     is never a descendant of any CSS-transformed element. A transform on
     an ancestor re-parents position:fixed, causing the modal to be sized
     and positioned relative to the card instead of the viewport.
══════════════════════════════════════════════════════════════════ -->
{%- unless skip_styles -%}
<!-- NOTE: No `hidden` attribute here. The HTML hidden attribute is
     implemented as [hidden]{display:none!important} in some browsers,
     which permanently overrides .is-open{display:flex}. Visibility is
     controlled exclusively via the .is-open CSS class. -->
<div
  class="ql-overlay"
  id="quickLookOverlay"
  role="dialog"
  aria-modal="true"
  aria-label="Quick look"
>
  <div class="ql-modal" id="quickLookModal">

    <button class="ql-close" id="quickLookClose" type="button" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <div class="ql-image">
      <img id="quickLookImage" src="" alt="">
    </div>

    <div class="ql-details">
      <div id="quickLookVendor" class="ql-vendor"></div>
      <h2 id="quickLookTitle" class="ql-title"></h2>

      <div class="ql-price-row">
        <span id="quickLookPrice" class="ql-price-current"></span>
        <span id="quickLookCompare" class="ql-price-compare"></span>
      </div>

      <p id="quickLookDesc" class="ql-description"></p>

      <div id="quickLookColorSection">
        <div class="ql-section-label">Color</div>
        <div id="quickLookSwatches" class="ql-swatches"></div>
      </div>

      <button id="quickLookAtcBtn" class="ql-atc-btn" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
        </svg>
        Add to Cart
      </button>

      <a id="quickLookFullLink" href="#" class="ql-full-link">View full details &rarr;</a>

      <div class="ql-trust-badges">
        <div class="ql-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-4"/>
            <path d="M12 16v3a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1v-3"/>
          </svg>
          Free shipping on orders over $150
        </div>
        <div class="ql-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
          Secure checkout guaranteed
        </div>
        <div class="ql-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
          Easy 30-day returns
        </div>
      </div>
    </div><!-- /.ql-details -->
  </div><!-- /.ql-modal -->
</div><!-- /.ql-overlay -->

<script>
(function () {
  if (window.__qlSetup) return;
  window.__qlSetup = true;

  var overlay   = document.getElementById('quickLookOverlay');
  var closeBtn  = document.getElementById('quickLookClose');
  var elImage   = document.getElementById('quickLookImage');
  var elVendor  = document.getElementById('quickLookVendor');
  var elTitle   = document.getElementById('quickLookTitle');
  var elPrice   = document.getElementById('quickLookPrice');
  var elCompare = document.getElementById('quickLookCompare');
  var elDesc    = document.getElementById('quickLookDesc');
  var elColSec  = document.getElementById('quickLookColorSection');
  var elSwatches= document.getElementById('quickLookSwatches');
  var elAtcBtn  = document.getElementById('quickLookAtcBtn');
  var elFullLink= document.getElementById('quickLookFullLink');

  // ── FIX 1: Move overlay to <body> ───────────────────────────────
  // CSS `transform` on any ancestor re-parents `position:fixed` elements,
  // causing the overlay to be sized/clipped to the transformed element
  // (in this case the hovered product card) instead of the viewport.
  // Moving it to <body> guarantees it is never inside a transformed ancestor.
  if (overlay.parentNode !== document.body) {
    document.body.appendChild(overlay);
  }

  // ── FIX 2: Class-only visibility ────────────────────────────────
  // We deliberately do NOT use the `hidden` HTML attribute. Many browsers
  // implement [hidden]{display:none!important} which overrides
  // .is-open{display:flex}, permanently preventing the modal from showing.
  // The .is-open class is the single source of truth for visibility.

  function openModal(btn) {
    var d = btn.dataset;

    elImage.src             = d.productImage || '';
    elImage.alt             = d.productTitle || '';
    elVendor.textContent    = d.productVendor || '';
    elVendor.style.display  = d.productVendor ? '' : 'none';
    elTitle.textContent     = d.productTitle  || '';
    elDesc.textContent      = d.productDescription || '';

    elPrice.textContent = d.productPrice || '';
    var onSale = d.productOnSale === 'true';
    elPrice.classList.toggle('on-sale', onSale);
    if (onSale && d.productComparePrice) {
      elCompare.textContent    = d.productComparePrice;
      elCompare.style.display  = '';
    } else {
      elCompare.style.display = 'none';
    }

    var colors = d.productColors ? d.productColors.split('|').filter(Boolean) : [];
    if (colors.length) {
      elColSec.style.display = '';
      elSwatches.innerHTML = colors.map(function(c, i) {
        var bg = c.toLowerCase().replace(/ /g, '');
        return '<span class="ql-swatch' + (i === 0 ? ' active' : '') + '" style="background-color:' + bg + '" title="' + c + '" aria-label="' + c + '"></span>';
      }).join('');
      elSwatches.querySelectorAll('.ql-swatch').forEach(function(sw) {
        sw.addEventListener('click', function() {
          elSwatches.querySelectorAll('.ql-swatch').forEach(function(s){ s.classList.remove('active'); });
          sw.classList.add('active');
        });
      });
    } else {
      elColSec.style.display = 'none';
    }

    var available = d.productAvailable === 'true';
    elAtcBtn.dataset.variantId = d.productVariantId || '';
    elAtcBtn.disabled = !available;
    elAtcBtn.classList.remove('go-to-cart', 'added');
    elAtcBtn.classList.toggle('disabled', !available);
    elAtcBtn.style.background = '';
    elAtcBtn.style.cursor = '';
    if (!available) {
      elAtcBtn.textContent = 'Sold Out';
    } else {
      elAtcBtn.innerHTML = ICON_CART + ' Add to Cart';
    }

    elFullLink.href = d.productUrl || '#';

    // Show via class only — no hidden attribute manipulation
    overlay.classList.add('is-open');
    document.body.classList.add('ql-no-scroll');
    closeBtn.focus();
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    document.body.classList.remove('ql-no-scroll');
  }

  document.addEventListener('click', function(e) {
    var qlBtn = e.target.closest('[data-ql-trigger]');
    if (qlBtn) { e.preventDefault(); openModal(qlBtn); return; }

    // Close when clicking the backdrop (the overlay itself, not the modal)
    if (e.target === overlay) { closeModal(); return; }

    var atcBtn = e.target.closest('.js-quick-atc');
    if (atcBtn) { e.preventDefault(); quickATC(atcBtn.dataset.variantId, atcBtn, false); return; }

    // ── Clicking the image area navigates to the full product page ──
    var mediaWrapper = e.target.closest('.card__media-wrapper');
    if (mediaWrapper) {
      // Don't interfere with hover-action buttons
      if (e.target.closest('.card__hover-actions')) return;
      // Read the URL from the Quick Look trigger's data attribute
      var trigger = mediaWrapper.querySelector('[data-ql-trigger]');
      if (trigger && trigger.dataset.productUrl) {
        window.location.href = trigger.dataset.productUrl;
      }
    }
    
  });

  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });

  elAtcBtn.addEventListener('click', function() {
    if (!elAtcBtn.disabled && elAtcBtn.dataset.variantId) {
      quickATC(elAtcBtn.dataset.variantId, elAtcBtn, true);
    }
  });

  // SVG icons reused across states
  var ICON_CART = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>';
  var ICON_CHECK = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
  var ICON_ARROW = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

  function updateCartBadges() {
    fetch('/cart.js')
      .then(function(r){ return r.json(); })
      .then(function(cart) {
        document.querySelectorAll('[data-cart-count], .cart-count-bubble').forEach(function(node) {
          node.textContent = cart.item_count;
        });
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      });
  }

  function quickATC(variantId, el, isModal) {
    if (!variantId || el.disabled) return;

    var origHTML = el.innerHTML;
    el.disabled  = true;
    el.style.background = '';

    // Step 1: "Adding…"
    el.innerHTML = isModal
      ? (ICON_CART + ' Adding&hellip;')
      : '&hellip;';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Cart add failed: ' + r.status);
      return r.json();
    })
    .then(function() {
      updateCartBadges();

      if (isModal) {
        // ── Modal button: Added → Go to Cart ────────────────────
        // Phase A: green "✓ Added" flash (700ms)
        el.innerHTML = ICON_CHECK + ' Added!';
        el.style.background = '#2d6a4f';
        el.disabled = true;

        setTimeout(function() {
          // Phase B: swap to "Go to Cart →" — still a button but navigates
          el.innerHTML = ICON_ARROW + ' Go to Cart';
          el.style.background = '#111';
          el.style.cursor = 'pointer';
          el.disabled = false;

          // One-time click: navigate to cart
          el.addEventListener('click', function goToCart() {
            el.removeEventListener('click', goToCart);
            window.location.href = '/cart';
          }, { once: true });
        }, 700);

      } else {
        // ── Card hover button: brief "✓" then "Go to Cart →" ────
        el.innerHTML = ICON_CHECK + ' Added';
        el.classList.add('added-state');

        setTimeout(function() {
          el.innerHTML = ICON_ARROW + ' Go to Cart';
          el.classList.remove('added-state');
          el.classList.add('go-to-cart-state');
          el.disabled = false;

          el.addEventListener('click', function goToCart(ev) {
            ev.preventDefault();
            el.removeEventListener('click', goToCart);
            window.location.href = '/cart';
          }, { once: true });

          // Auto-reset after 4s so card returns to normal if user doesn't navigate
          setTimeout(function() {
            el.classList.remove('go-to-cart-state');
            el.innerHTML = origHTML;
            el.style.background = '';
          }, 4000);
        }, 700);
      }
    })
    .catch(function(err) {
      console.error('[QuickATC]', err);
      el.disabled      = false;
      el.innerHTML     = origHTML;
      el.style.background = '';
    });
  }
})();
</script>
{%- endunless -%}
